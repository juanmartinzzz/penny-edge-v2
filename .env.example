# Cloudflare credentials for Wrangler (deploy / whoami / etc.)
# Docs: https://developers.cloudflare.com/workers/wrangler/system-environment-variables/
#
# Create a token: https://dash.cloudflare.com/profile/api-tokens
# Recommended: "Edit Cloudflare Workers" template (or custom with Workers Scripts:Edit)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Production API Worker — local Vite talks to this directly (no local backend)
VITE_API_URL=https://penny-edge-api.juan-martinzzz.workers.dev
